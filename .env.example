# .env.example — copie para .env e preencha com suas credenciais reais
# NUNCA commite o .env com senhas reais

ENVIRONMENT=production

# ---- Banco do CP (gerenciado pelo Compose) --------------------------------
CP_DB_NAME=capacidade_produtiva
CP_DB_USER=cp_user
CP_DB_PASSWORD=troque_esta_senha

# ---- API ------------------------------------------------------------------
CP_API_PORT=3050

# ---- Banco SAP (externo, somente leitura) ---------------------------------
SAP_DB_HOST=192.168.1.100
SAP_DB_PORT=5432
SAP_DB_NAME=sap
SAP_DB_USER=cp_readonly
SAP_DB_PASSWORD=senha_do_sap

# ---- Autenticacao ---------------------------------------------------------
# Mesma chave usada pelo servico de autenticacao SAP para assinar os JWTs
JWT_SECRET=gere_com_openssl_rand_base64_48
AUTH_URL=http://sap-auth:3001
AUTH_ADMIN_USER=usuario_admin
AUTH_ADMIN_PASSWORD=senha_admin
